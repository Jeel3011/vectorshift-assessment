# Backend environment variables — copy to .env and fill in real values.
# NEVER commit .env to source control.

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (local dev).
# Port 3100 is this project's frontend (3000 is reserved for DocQuery).
# Deployed *.vercel.app origins are matched automatically via ALLOWED_ORIGIN_REGEX.
ALLOWED_ORIGINS=http://localhost:3100
ALLOWED_ORIGIN_REGEX=https://.*\.vercel\.app

# ── JWT Authentication ─────────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-random-256-bit-secret
JWT_ALGORITHM=HS256

# ── Graph size limits (tune for your workload) ────────────────────────────────
MAX_NODES=500
MAX_EDGES=2000
MAX_ID_LEN=128
